# Fastify server — local development
# Copy: cp .env.example .env
# Matches the DB credentials in docker-compose.dev.yml

DATABASE_URL=postgresql://wms:wms@localhost:5432/wms

# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_jwt_secret_32chars_minimum
AGENT_JWT_SECRET=change_me_agent_jwt_secret_32chars

CORS_ORIGIN=http://localhost:3000
PORT=4000
ALERT_INTERVAL_MS=15000
