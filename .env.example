# Database
DB_PASSWORD=change_me_strong_password

# JWT secrets — generate with: openssl rand -hex 32
JWT_SECRET=change_me_jwt_secret_32chars_minimum
AGENT_JWT_SECRET=change_me_agent_jwt_secret_32chars

# CORS / public URLs (set to your actual domain in production)
CORS_ORIGIN=https://localhost
NEXT_PUBLIC_API_URL=https://localhost/api
NEXT_PUBLIC_WS_URL=wss://localhost/ws/live

# Caddy hostname (domain or "localhost")
CADDY_HOST=localhost

# Network discovery
SCAN_CIDRS=192.168.1.0/24
SCAN_CONCURRENCY=20
SCAN_TIMEOUT_MS=1000

# Alert watchdog interval (ms)
ALERT_INTERVAL_MS=60000
